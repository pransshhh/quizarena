{
  "name": "@quizarena/server",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf node_modules dist .turbo"
  },
  "devDependencies": {
    "@quizarena/typescript-config": "*",
    "@types/bun": "^1.3.12",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "@quizarena/shared": "*",
    "express": "^5.2.1",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  }
}
